+final class ReplayCaptureTestCase: XCTestCase {
+
+    func testReplayCaptureContainsCompletedLoopDecision() throws {
+        let loopDate = Date(timeIntervalSince1970: 1_700_000_000)
+        let statusDate = loopDate.addingTimeInterval(10)
+        let loopIdentifier = UUID(uuidString: "11111111-1111-1111-1111-111111111111")!
+        let statusIdentifier = UUID(uuidString: "22222222-2222-2222-2222-222222222222")!
+        let settingsIdentifier = UUID(uuidString: "33333333-3333-3333-3333-333333333333")!
+        let glucoseUnit = HKUnit.milligramsPerDeciliter
+        let effect = GlucoseEffect(
+            startDate: loopDate,
+            quantity: HKQuantity(unit: glucoseUnit, doubleValue: -2.5)
+        )
+
+        let loopDecision = StoredDosingDecision(
+            date: loopDate,
+            reason: "loop",
+            settings: StoredDosingDecision.Settings(syncIdentifier: settingsIdentifier),
+            historicalGlucose: [
+                HistoricalGlucoseValue(
+                    startDate: loopDate.addingTimeInterval(-300),
+                    quantity: HKQuantity(unit: glucoseUnit, doubleValue: 108)
+                ),
+                HistoricalGlucoseValue(
+                    startDate: loopDate,
+                    quantity: HKQuantity(unit: glucoseUnit, doubleValue: 110)
+                )
+            ],
+            carbsOnBoard: CarbValue(startDate: loopDate, value: 12),
+            insulinOnBoard: InsulinValue(startDate: loopDate, value: 1.25),
+            predictedGlucose: [
+                PredictedGlucoseValue(
+                    startDate: loopDate,
+                    quantity: HKQuantity(unit: glucoseUnit, doubleValue: 110)
+                ),
+                PredictedGlucoseValue(
+                    startDate: loopDate.addingTimeInterval(300),
+                    quantity: HKQuantity(unit: glucoseUnit, doubleValue: 105)
+                )
+            ],
+            replayPredictionEffects: StoredDosingDecision.ReplayPredictionEffects(
+                enabledEffectsRawValue: 15,
+                insulin: [effect],
+                carbs: [effect],
+                momentum: [effect],
+                retrospection: [effect]
+            ),
+            automaticDoseRecommendation: AutomaticDoseRecommendation(
+                basalAdjustment: TempBasalRecommendation(unitsPerHour: 0.7, duration: 30 * 60),
+                bolusUnits: 0.25
+            ),
+            syncIdentifier: loopIdentifier
+        )
+        let statusDecision = StoredDosingDecision(
+            date: statusDate,
+            reason: "updateRemoteRecommendation",
+            syncIdentifier: statusIdentifier
+        )
+
+        let dictionary = try XCTUnwrap(
+            statusDecision.replayCaptureTestingDetails(automaticDoseDecision: loopDecision)
+        )
+
+        XCTAssertTrue(JSONSerialization.isValidJSONObject(dictionary))
+        XCTAssertLessThan(try JSONSerialization.data(withJSONObject: dictionary).count, 20_000)
+        let capture = try XCTUnwrap(dictionary["replayCapture"] as? [String: Any])
+        XCTAssertEqual(capture["schemaVersion"] as? Int, 3)
+        XCTAssertEqual(capture["captureRole"] as? String, "completedLoopDecision")
+        XCTAssertEqual(capture["loopDecisionSyncIdentifier"] as? String, loopIdentifier.uuidString)
+        XCTAssertEqual(capture["statusDecisionSyncIdentifier"] as? String, statusIdentifier.uuidString)
+        XCTAssertEqual(capture["settingsSyncIdentifier"] as? String, settingsIdentifier.uuidString)
+
+        let prediction = try XCTUnwrap(capture["dosingPrediction"] as? [String: Any])
+        XCTAssertEqual(prediction["values"] as? [Double], [110, 105])
+        let predictionEffects = try XCTUnwrap(capture["predictionEffects"] as? [String: Any])
+        XCTAssertEqual(predictionEffects["enabledEffectsRawValue"] as? Int, 15)
+        XCTAssertEqual((predictionEffects["insulin"] as? [[String: Any]])?.first?["mgdl"] as? Double, -2.5)
+        XCTAssertEqual((predictionEffects["carbs"] as? [[String: Any]])?.count, 1)
+        XCTAssertEqual((predictionEffects["momentum"] as? [[String: Any]])?.count, 1)
+        XCTAssertEqual((predictionEffects["retrospection"] as? [[String: Any]])?.count, 1)
+        let recommendation = try XCTUnwrap(capture["automaticDoseRecommendation"] as? [String: Any])
+        XCTAssertEqual(recommendation["bolusVolume"] as? Double, 0.25)
+        XCTAssertEqual((capture["historicalGlucose"] as? [[String: Any]])?.count, 2)
+    }
+
+    func testReplayCaptureIsAbsentWithoutCompletedLoopDecision() throws {
+        let statusDecision = StoredDosingDecision(reason: "updateRemoteRecommendation")
+
+        XCTAssertNil(statusDecision.replayCaptureTestingDetails(automaticDoseDecision: nil))
+    }
 }
