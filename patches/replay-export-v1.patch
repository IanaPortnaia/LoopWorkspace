+    func replayCaptureTestingDetails(automaticDoseDecision: StoredDosingDecision?) -> [String: Any]? {
+        guard let loopDecision = automaticDoseDecision, loopDecision.reason == "loop" else {
+            return nil
+        }
+
+        let formatter = ISO8601DateFormatter()
+        var capture: [String: Any] = [
+            "schemaVersion": 1,
+            "captureRole": "completedLoopDecision",
+            "statusDecisionSyncIdentifier": syncIdentifier.uuidString,
+            "statusDecisionReason": reason,
+            "statusDecisionTimestamp": formatter.string(from: date),
+            "loopDecisionSyncIdentifier": loopDecision.syncIdentifier.uuidString,
+            "loopDecisionReason": loopDecision.reason,
+            "loopDecisionTimestamp": formatter.string(from: loopDecision.date),
+            "historicalGlucose": loopDecision.replayCaptureHistoricalGlucose
+        ]
+
+        if let settingsSyncIdentifier = loopDecision.settings?.syncIdentifier {
+            capture["settingsSyncIdentifier"] = settingsSyncIdentifier.uuidString
+        }
+        if let prediction = loopDecision.replayCapturePrediction {
+            capture["dosingPrediction"] = prediction
+        }
+        if let recommendation = loopDecision.replayCaptureRecommendation {
+            capture["automaticDoseRecommendation"] = recommendation
+        }
+        if let iob = loopDecision.loopStatusIOB {
+            capture["iob"] = iob.dictionaryRepresentation
+        }
+        if let cob = loopDecision.loopStatusCOB {
+            capture["cob"] = cob.dictionaryRepresentation
+        }
+        if !loopDecision.warnings.isEmpty {
+            capture["warningIdentifiers"] = loopDecision.warnings.map(\.id)
+        }
+        if !loopDecision.errors.isEmpty {
+            capture["errorIdentifiers"] = loopDecision.errors.map(\.id)
+        }
+
+        return ["replayCapture": capture]
+    }
